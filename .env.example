# Runtime configuration
HY3D_MODEL_PATH=tencent/Hunyuan3D-2.1
HY3D_SHAPE_SUBFOLDER=hunyuan3d-dit-v2-1
HY3D_TEXGEN_MODEL_PATH=tencent/Hunyuan3D-2.1
HY3D_DEVICE=cuda
HY3D_CACHE_PATH=./save_dir
HY3D_DISABLE_TEX=0
HY3D_LOW_VRAM_MODE=0
HY3D_DINO_MODEL_PATH=facebook/dinov2-giant
HY3D_REALESRGAN_PATH=hy3dpaint/ckpt/RealESRGAN_x4plus.pth
HY3D_TEX_CFG_PATH=hy3dpaint/cfgs/hunyuan-paint-pbr.yaml
HY3D_TEX_CUSTOM_PIPELINE=hy3dpaint/hunyuanpaintpbr

# Deployment automation defaults
HF_SPACE_NAMESPACE=
HF_SPACE_NAME=
HF_SPACE_SDK=gradio
HF_SPACE_AUTO_SYNC=false
HF_CLI_BIN=huggingface-cli